{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    }
  ],
  "crons": [
    {
      "path": "/api/sellers/sidebar-counts/update",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/buyers/update-sidebar-counts",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/price-reduction-notification",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/work-task-deadline-notification",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/work-task-upcoming-deadline-notification",
      "schedule": "0 0,7 * * *"
    },
    {
      "path": "/api/cron/business-site-deadline-hourly-notification",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reset-private-mail-delivery",
      "schedule": "0 15 * * *"
    }
  ]
}
