{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/buyer-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/work-task-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/seller-sync",
      "schedule": "*/5 * * * *"
    }
  ]
}
