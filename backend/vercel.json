{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/sellers/sidebar-counts/update",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/buyers/update-sidebar-counts",
      "schedule": "*/10 * * * *"
    }
  ]
}
