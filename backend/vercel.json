{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**/*", "google-service-account.json"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/buyer-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/work-task-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/seller-sync",
      "schedule": "*/5 * * * *"
    }
  ]
}
